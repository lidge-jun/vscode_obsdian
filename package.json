{
	"name": "vscode-obsdian",
	"displayName": "vscode_obsdian",
	"description": "Office and Markdown viewer for VS Code, based on MIT-licensed vscode-office with attribution preserved.",
	"version": "3.7.5",
	"publisher": "jun6161",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lidge-jun/vscode_obsdian.git"
	},
	"homepage": "https://github.com/lidge-jun/vscode_obsdian#readme",
	"bugs": {
		"url": "https://github.com/lidge-jun/vscode_obsdian/issues"
	},
	"icon": "images/logo-new.png",
	"engines": {
		"vscode": "^1.64.0"
	},
	"keywords": [
		"pdf",
		"word",
		"markdown",
		"notes",
		"xlsx",
		"excel"
	],
	"categories": [
		"Visualization",
		"Other"
	],
	"activationEvents": [
		"onStartupFinished",
		"onCustomEditor:cweijan.officeViewer",
		"onCustomEditor:cweijan.hwpEditor",
		"onCustomEditor:cweijan.imageViewer",
		"onCustomEditor:cweijan.markdownViewer",
		"onCustomEditor:cweijan.markdownViewer.optional",
		"onCustomEditor:cweijan.htmlViewer"
	],
	"main": "./out/extension.js",
	"contributes": {
		"themes": [
			{
				"label": "One Dark Modern",
				"uiTheme": "vs-dark",
				"path": "./theme/onedark-modern.json"
			},
			{
				"label": "One Dark Modern Classic",
				"uiTheme": "vs-dark",
				"path": "./theme/onedark-modern-classic.json"
			}
		],
		"languages": [
			{
				"id": "reg",
				"aliases": [
					"REG",
					"reg"
				],
				"extensions": [
					".reg",
					".REG"
				],
				"configuration": "./syntaxes/reg-language-configuration.json"
			},
			{
				"id": "http",
				"aliases": [
					"HTTP",
					"Http",
					"http"
				],
				"extensions": [
					".http",
					".rest"
				],
				"firstLine": "^(GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS|CONNECT|TRACE)\\s+(.*?)HTTP/[0-9\\.]+$",
				"configuration": "./syntaxes/http-language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "reg",
				"scopeName": "source.reg",
				"path": "./syntaxes/reg.tmLanguage"
			},
			{
				"language": "http",
				"scopeName": "source.http",
				"path": "./syntaxes/http.tmLanguage.json"
			}
		],
		"snippets": [
			{
				"language": "http",
				"path": "./snippets/http.json"
			}
		],
		"commands": [
			{
				"command": "office.quickOpen",
				"title": "Quick open",
				"category": "ShortcutMenuBar",
				"icon": "$(files)"
			},
			{
				"command": "vscode-office.save-response-body",
				"title": "Save Response",
				"icon": "$(save)"
			},
			{
				"command": "vscode-office.copy-response-body",
				"title": "Copy Response",
				"icon": "$(copy)"
			},
			{
				"command": "office.reg.jumpToKey",
				"title": "REG: Jump to registry key"
			},
			{
				"command": "office.markdown.switch",
				"title": "Switch markdown editor",
				"icon": {
					"dark": "./images/switch.svg",
					"light": "./images/switch_light.svg"
				}
			},
			{
				"command": "office.markdown.paste",
				"title": "Enhance paste in markdown"
			},
			{
				"command": "office.html.preview",
				"title": "Preview HTML"
			},
			{
				"command": "vscode-obsdian.previewLegacyPresentation",
				"title": "Preview Legacy PowerPoint with LibreOffice"
			}
		],
		"keybindings": [
			{
				"command": "office.markdown.paste",
				"key": "ctrl+v",
				"mac": "cmd+v",
				"when": "!terminalFocus && !filesExplorerFocus && resourceLangId == markdown"
			},
			{
				"command": "office.html.preview",
				"key": "ctrl+shift+v",
				"when": "editorTextFocus && editorLangId == html"
			},
			{
				"command": "office.markdown.switch",
				"key": "ctrl+alt+e",
				"mac": "ctrl+cmd+e",
				"when": "editorTextFocus && editorLangId == markdown"
			},
			{
				"command": "vscode-office.request",
				"key": "ctrl+enter",
				"mac": "cmd+enter",
				"when": "editorTextFocus && editorLangId == 'http'"
			}
		],
		"menus": {
			"editor/title": [
				{
					"when": "config.vscode-office.quickOpen",
					"command": "office.quickOpen",
					"group": "navigation@10"
				},
				{
					"command": "office.markdown.switch",
					"when": "resourceExtname == '.md'",
					"group": "navigation@-2"
				},
				{
					"when": "editorTextFocus && resourceScheme == rest-client-response",
					"command": "vscode-office.copy-response-body",
					"group": "navigation@0"
				},
				{
					"when": "editorTextFocus && resourceScheme == rest-client-response",
					"command": "vscode-office.save-response-body",
					"group": "navigation@2"
				}
			],
			"editor/context": [
				{
					"command": "office.html.preview",
					"group": "navigation@1",
					"when": "editorTextFocus && editorLangId == html"
				},
				{
					"command": "vscode-office.save-response-body",
					"group": "http@2",
					"when": "editorTextFocus && resourceScheme == rest-client-response"
				},
				{
					"command": "vscode-office.copy-response-body",
					"group": "http@4",
					"when": "editorTextFocus && resourceScheme == rest-client-response"
				}
			],
			"explorer/context": [
				{
					"command": "vscode-obsdian.previewLegacyPresentation",
					"group": "navigation",
					"when": "resourceExtname == '.ppt'"
				}
			]
		},
		"customEditors": [
			{
				"viewType": "cweijan.officeViewer",
				"displayName": "vscode_obsdian Office Viewer",
				"selector": [
					{
						"filenamePattern": "*.xlsx"
					},
					{
						"filenamePattern": "*.xlsm"
					},
					{
						"filenamePattern": "*.csv"
					},
					{
						"filenamePattern": "*.xls"
					},
					{
						"filenamePattern": "*.ods"
					},
					{
						"filenamePattern": "*.docx"
					},
					{
						"filenamePattern": "*.dotx"
					},
					{
						"filenamePattern": "*.pptx"
					},
					{
						"filenamePattern": "*.pdf"
					},
					{
						"filenamePattern": "*.ttf"
					},
					{
						"filenamePattern": "*.woff"
					},
					{
						"filenamePattern": "*.woff2"
					},
					{
						"filenamePattern": "*.otf"
					},
					{
						"filenamePattern": "*.jar"
					},
					{
						"filenamePattern": "*.zip"
					},
					{
						"filenamePattern": "*.rar"
					},
					{
						"filenamePattern": "*.apk"
					},
					{
						"filenamePattern": "*.vsix"
					},
					{
						"filenamePattern": "*.svg"
					}
				]
			},
				{
					"viewType": "cweijan.hwpEditor",
					"displayName": "HWP/HWPX Editor (vscode_obsdian)",
					"priority": "default",
					"selector": [
					{
						"filenamePattern": "*.hwp"
					},
					{
						"filenamePattern": "*.hwpx"
					}
				]
			},
			{
				"viewType": "cweijan.imageViewer",
				"displayName": "Image Preview (vscode_obsdian)",
				"priority": "option",
				"selector": [
					{
						"filenamePattern": "*.jpg"
					},
					{
						"filenamePattern": "*.png"
					},
					{
						"filenamePattern": "*.gif"
					},
					{
						"filenamePattern": "*.apng"
					},
					{
						"filenamePattern": "*.bmp"
					},
					{
						"filenamePattern": "*.ico"
					},
					{
						"filenamePattern": "*.cur"
					},
					{
						"filenamePattern": "*.jpeg"
					},
					{
						"filenamePattern": "*.pjpeg"
					},
					{
						"filenamePattern": "*.pjp"
					},
					{
						"filenamePattern": "*.tif"
					},
					{
						"filenamePattern": "*.webp"
					}
				]
			},
			{
				"viewType": "cweijan.markdownViewer",
				"displayName": "Markdown Notes Editor",
				"selector": [
					{
						"filenamePattern": "file:/**/*.md"
					},
					{
						"filenamePattern": "file:/**/*.markdown"
					}
				]
			},
			{
				"viewType": "cweijan.markdownViewer.optional",
				"displayName": "Markdown Notes Editor (Optional)",
				"priority": "option",
				"selector": [
					{
						"filenamePattern": "*.md"
					},
					{
						"filenamePattern": "*.markdown"
					}
				]
			},
			{
				"viewType": "cweijan.htmlViewer",
				"displayName": "HTML Viewer",
				"priority": "option",
				"selector": [
					{
						"filenamePattern": "*.html"
					},
					{
						"filenamePattern": "*.htm"
					}
				]
			}
		],
		"configuration": {
			"type": "object",
			"title": "vscode_obsdian",
			"properties": {
				"vscode-office.quickOpen": {
					"title": "Quick open",
					"type": "boolean",
					"default": false,
					"description": "show icon for Go to File, 'Quick Open'"
				},
				"vscode-office.viewAbsoluteLocal": {
					"type": "boolean",
					"default": false,
					"description": "Support view absolute path image from markdown viewer."
				},
				"vscode-office.chromiumPath": {
					"type": "string",
					"description": "Set the chromium browser location for exporting markdown pdf."
				},
				"vscode-office.pdfMarginTop": {
					"type": "integer",
					"default": 25,
					"description": "Printed pdf default top margin."
				},
				"vscode-office.editorMode": {
					"type": "string",
					"enum": [
						"wysiwyg",
						"ir",
						"sv"
					],
					"enumDescriptions": [
						"What You See Is What You Get (WYSIWYG editing)",
						"Instant Rendering (inline preview while editing)",
						"Split View (edit on left, preview on right)"
					],
					"default": "wysiwyg",
					"description": "Default editing mode for the Markdown editor."
				},
				"vscode-office.openOutline": {
					"type": "boolean",
					"default": true,
					"description": "Open markdown outline."
				},
				"vscode-office.hideToolbar": {
					"type": "boolean",
					"default": false,
					"description": "Hide markdown toolbar."
				},
				"vscode-office.previewCode": {
					"type": "boolean",
					"default": true,
					"description": "Preview code in markdown."
				},
				"vscode-office.preventMacOptionKey": {
					"type": "boolean",
					"default": true,
					"description": "Prevent MacOS option key in the markdown editor."
				},
				"vscode-office.editorTheme": {
					"type": "string",
					"enum": [
						"Auto",
						"Light",
						"Solarized"
					],
					"default": "Light",
					"markdownDescription": "The theme for the Markdown editor."
				},
				"vscode-office.previewCodeHighlight.style": {
					"type": "string",
					"enum": [
						"abap",
						"algol",
						"algol_nu",
						"arduino",
						"autumn",
						"borland",
						"bw",
						"colorful",
						"dracula",
						"emacs",
						"friendly",
						"fruity",
						"github",
						"igor",
						"lovelace",
						"manni",
						"monokai",
						"monokailight",
						"murphy",
						"native",
						"paraiso-dark",
						"paraiso-light",
						"pastie",
						"perldoc",
						"pygments",
						"rainbow_dash",
						"rrt",
						"solarized-dark",
						"solarized-dark256",
						"solarized-light",
						"swapoff",
						"tango",
						"trac",
						"vim",
						"vs",
						"xcode",
						"ant-design"
					],
					"default": "dracula",
					"markdownDescription": "Default syntax highlight style of markdown preview code. Refer to [Chroma Style Gallery](https://xyproto.github.io/splash/docs/longer/all.html). Only applies when `#vscode-office.previewCode#` is enabled."
				},
				"vscode-office.previewCodeHighlight.showLineNumber": {
					"type": "boolean",
					"default": true,
					"markdownDescription": "Show line numbers in markdown preview code window. Only applies when `#vscode-office.previewCode#` is enabled."
				},
				"vscode-office.editorLanguage": {
					"type": "string",
					"enum": [
						"en_US",
						"ja_JP",
						"ko_KR",
						"ru_RU",
						"zh_CN",
						"zh_TW"
					],
					"default": "en_US",
					"description": "You could change your editor language."
				},
				"vscode-office.workspacePathAsImageBasePath": {
					"type": "boolean",
					"default": false,
					"description": "Using workspace path as markdown image base path."
				},
				"vscode-office.pptx.libreOfficePath": {
					"type": "string",
					"default": "",
					"description": "LibreOffice executable path for optional legacy .ppt PDF preview."
				},
				"vscode-office.pptx.conversionTimeoutMs": {
					"type": "integer",
					"default": 30000,
					"minimum": 1000,
					"description": "LibreOffice legacy .ppt conversion timeout in milliseconds."
				},
				"vscode-obsdian.hwp.experimentalSave": {
					"type": "boolean",
					"default": true,
					"description": "Show the HWP/HWPX toolbar save button. VS Code native save remains available for dirty custom editor documents."
				},
				"vscode-obsdian.hwp.studioUrl": {
					"type": "string",
					"default": "",
					"description": "Optional trusted remote rhwp studio URL. Leave empty to use the bundled local rhwp-studio with full HWP/HWPX editing."
				},
				"vscode-office.pasterImgPath": {
					"type": "string",
					"default": "image/${fileName}/${now}.png",
					"description": "Markdown paste image path, variables: workspaceDir, fileName, now."
				}
			}
		}
	},
	"scripts": {
		"dev": "vite --mode=development",
		"lint:fix": "eslint src/**/*.ts --fix",
		"build": "rm -rf out && vite build --mode=production",
		"test:hwp-hardening": "node scripts/verify-hwp-hardening.mjs",
		"package": "vsce package --no-dependencies",
		"publish": "vsce publish --no-dependencies",
		"vscode:prepublish": "npm run build"
	},
	"devDependencies": {
		"@types/adm-zip": "^0.5.0",
		"@types/node": "^22.10.0",
		"@types/react": "^18.2.66",
		"@types/react-dom": "^18.2.22",
		"@types/vscode": "^1.64.0",
		"@typescript-eslint/eslint-plugin": "^7.1.1",
		"@typescript-eslint/parser": "^7.1.1",
		"@vitejs/plugin-react": "^4.2.1",
		"esbuild": "^0.14.54",
		"esbuild-plugin-copy": "^1.3.0",
		"eslint": "^8.57.0",
		"eslint-plugin-import": "^2.29.1",
		"eslint-plugin-react": "^7.34.1",
		"eslint-plugin-react-hooks": "^4.6.0",
		"eslint-plugin-react-refresh": "^0.4.6",
		"eslint-plugin-unused-imports": "^3.1.0",
		"less": "^4.2.0",
		"node-unrar-js": "^2.0.2",
		"vite": "^6.2.5"
	},
	"dependencies": {
		"@ant-design/icons": "^5.3.5",
		"adm-zip": "^0.5.10",
		"antd": "^5.15.4",
		"cheerio": "^1.0.0",
		"chrome-finder": "^1.0.7",
		"date-format": "^4.0.14",
		"docx-preview": "^0.3.7",
		"file-type": "^19.6.0",
		"highlight.js": "^11.10.0",
		"iconv-lite": "^0.6.3",
		"katex": "^0.16.2",
		"markdown-it": "^14.1.0",
		"markdown-it-anchor": "^9.2.0",
		"markdown-it-checkbox": "^1.1.0",
		"markdown-it-plantuml": "^1.4.1",
		"markdown-it-toc-done-right": "^4.2.0",
		"mustache": "^4.0.1",
		"opentype.js": "^1.3.4",
		"pdf-lib": "^1.11.2",
		"puppeteer-core": "^1.20.0",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-image-gallery": "^1.3.0",
		"vscode-html-to-docx": "^1.1.2",
		"x-data-spreadsheet": "^1.1.9",
		"xlsx": "^0.18.5",
		"xlsx-js-style": "^1.2.0"
	}
}
